# =====================================================
# Converse AI Platform — Environment Variables
# =====================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =====================================================

# ─────────────────────────────────────────────────────
# GENERAL
# ─────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=json
SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=converse
POSTGRES_PASSWORD=converse_secret_change_me
POSTGRES_DB=converse

# Per-service databases (true microservice isolation)
AUTH_DB_NAME=converse_auth
USER_DB_NAME=converse_users
ORG_DB_NAME=converse_orgs
AGENT_DB_NAME=converse_agents
CONVERSATION_DB_NAME=converse_conversations
WORKFLOW_DB_NAME=converse_workflows
WEBHOOK_DB_NAME=converse_webhooks
KNOWLEDGE_DB_NAME=converse_knowledge
LLM_DB_NAME=converse_llm
PROMPT_DB_NAME=converse_prompts
ANALYTICS_DB_NAME=converse_analytics
NOTIFICATION_DB_NAME=converse_notifications
AUDIT_DB_NAME=converse_audit
BILLING_DB_NAME=converse_billing
ADMIN_DB_NAME=converse_admin
SEARCH_DB_NAME=converse_search

# ─────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_change_me
REDIS_DB=0
REDIS_SSL=false

# ─────────────────────────────────────────────────────
# Kafka
# ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_CONSUMER_GROUP_PREFIX=converse

# ─────────────────────────────────────────────────────
# JWT / Authentication
# ─────────────────────────────────────────────────────
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem

# ─────────────────────────────────────────────────────
# OAuth2 Providers
# ─────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback/google

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback/github

# ─────────────────────────────────────────────────────
# Google Cloud Platform
# ─────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ─────────────────────────────────────────────────────
# Dialogflow CX
# ─────────────────────────────────────────────────────
DIALOGFLOW_CX_LOCATION=us-central1
DIALOGFLOW_CX_DEFAULT_LANGUAGE=en

# ─────────────────────────────────────────────────────
# Vertex AI / Gemini
# ─────────────────────────────────────────────────────
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash
VERTEX_AI_EMBEDDING_MODEL=text-embedding-005

# ─────────────────────────────────────────────────────
# OpenAI Compatible Provider
# ─────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_ORG_ID=

# ─────────────────────────────────────────────────────
# Anthropic Compatible Provider
# ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# ─────────────────────────────────────────────────────
# S3 Compatible Object Storage (MinIO for local dev)
# ─────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin_secret_change_me
S3_REGION=us-east-1
S3_BUCKET_KNOWLEDGE_BASE=converse-knowledge-base
S3_BUCKET_EXPORTS=converse-exports
S3_BUCKET_MEDIA=converse-media
S3_USE_SSL=false

# ─────────────────────────────────────────────────────
# Observability — OpenTelemetry
# ─────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=converse-api-gateway
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# ─────────────────────────────────────────────────────
# Observability — Prometheus
# ─────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ─────────────────────────────────────────────────────
# Observability — Grafana
# ─────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_secret_change_me

# ─────────────────────────────────────────────────────
# Observability — Jaeger
# ─────────────────────────────────────────────────────
JAEGER_UI_PORT=16686
JAEGER_COLLECTOR_PORT=14268

# ─────────────────────────────────────────────────────
# Celery
# ─────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS=100
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW_SECONDS=60

# ─────────────────────────────────────────────────────
# Email / SMTP (Notifications)
# ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@converse.ai
SMTP_USE_TLS=true

# ─────────────────────────────────────────────────────
# Webhook Signing
# ─────────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=change-me-to-a-random-string

# ─────────────────────────────────────────────────────
# Service Ports (Local Development)
# ─────────────────────────────────────────────────────
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
ORG_SERVICE_PORT=8003
AGENT_SERVICE_PORT=8004
DIALOGFLOW_SERVICE_PORT=8005
CONVERSATION_SERVICE_PORT=8006
WORKFLOW_SERVICE_PORT=8007
WEBHOOK_SERVICE_PORT=8008
KNOWLEDGE_SERVICE_PORT=8009
LLM_GATEWAY_PORT=8010
PROMPT_SERVICE_PORT=8011
ANALYTICS_SERVICE_PORT=8012
NOTIFICATION_SERVICE_PORT=8013
AUDIT_SERVICE_PORT=8014
BILLING_SERVICE_PORT=8015
ADMIN_SERVICE_PORT=8016
VOICE_GATEWAY_PORT=8017
CHANNEL_GATEWAY_PORT=8018
SEARCH_SERVICE_PORT=8019

# ─────────────────────────────────────────────────────
# Service Internal URLs
# ─────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:8001
USER_SERVICE_URL=http://localhost:8002
ORG_SERVICE_URL=http://localhost:8003
AGENT_SERVICE_URL=http://localhost:8004
DIALOGFLOW_SERVICE_URL=http://localhost:8005
CONVERSATION_SERVICE_URL=http://localhost:8006
WORKFLOW_SERVICE_URL=http://localhost:8007
WEBHOOK_SERVICE_URL=http://localhost:8008
KNOWLEDGE_SERVICE_URL=http://localhost:8009
LLM_GATEWAY_URL=http://localhost:8010
PROMPT_SERVICE_URL=http://localhost:8011
ANALYTICS_SERVICE_URL=http://localhost:8012
NOTIFICATION_SERVICE_URL=http://localhost:8013
AUDIT_SERVICE_URL=http://localhost:8014
BILLING_SERVICE_URL=http://localhost:8015
ADMIN_SERVICE_URL=http://localhost:8016
VOICE_GATEWAY_URL=http://localhost:8017
CHANNEL_GATEWAY_URL=http://localhost:8018
SEARCH_SERVICE_URL=http://localhost:8019

# ─────────────────────────────────────────────────────
# Billing / Stripe
# ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────
# Channel Integrations
# ─────────────────────────────────────────────────────
# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_ID=

# Microsoft Teams
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=

# Telegram
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────────────────
# Voice Gateway
# ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Cloud Speech
SPEECH_TO_TEXT_MODEL=latest_long
TEXT_TO_SPEECH_VOICE=en-US-Neural2-D
